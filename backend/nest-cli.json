{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "features/chat/prompts/*.txt", "outDir": "./dist" },
      { "include": "public/**", "outDir": "./dist" }
    ],
    "watchAssets": true
  }
}
