# Supabase — copy from:
# Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Auth — copy from:
# Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# LLM Provider for chat  — 'gemini' | 'openai' | 'anthropic'
LLM_CHAT_PROVIDER=gemini
LLM_CHAT_API_KEY=your_google_api_key_here
LLM_CHAT_MODEL=gemini-2.5-flash

# LLM Provider for embeddings — 'gemini' | 'openai'
# Defaults to the chat provider/key if not set
LLM_EMBEDDING_PROVIDER=gemini
LLM_EMBEDDING_API_KEY=your_google_api_key_here
LLM_EMBEDDING_MODEL=gemini-embedding-001

# Legacy fallback (still supported as default API key source)
GOOGLE_API_KEY=your_google_api_key_here

# App
PORT=3000
# Public URL of this backend (used in verification email links)
APP_URL=http://localhost:3000
# Public URL of the frontend (used for post-verification redirect)
FRONTEND_URL=http://localhost:5173

# RAG tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
WEB_CRAWL_MAX_PAGES=30

# Firecrawl web crawling
FIRECRAWL_API_KEY=your_key_here

# Agentic loop safety cap (increase for broad questions like summaries)
MAX_TOOL_ITERATIONS=10
